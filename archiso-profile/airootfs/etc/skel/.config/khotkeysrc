# edpearOS KDE Custom Keyboard Shortcuts
# Student-focused shortcuts mapped to Super key

[edpearos-notes]
Comment=Open Notes (Obsidian)
Enabled=true
Name=Open Notes
Type=SIMPLE_ACTION_DATA
[edpearos-notes][Data]
[edpearos-notes][Data][1st Key]
Type=COMMAND_URL
CommandURL=obsidian
[edpearos-notes][Triggers]
[edpearos-notes][Triggers][Shortcut Trigger 0]
Type=SHORTCUT
Key=Meta+N

