[Desktop]
DesktopWallpaperRenderer=org.kde.image
Theme=default
Wallpaper=/usr/share/edpearos/wallpapers/default.png

[KDE]
widgetStyle=kvantum

[kdeglobals][General]
ColorScheme=EdpearOSTokyo

[kdeglobals][Icons]
Theme=Papirus-Dark

[kdeglobals][KDE]
SingleClick=false
AnimationDurationFactor=0.5
LookAndFeelPackage=org.edpearos.desktop

[kwinrc][org.kde.kdecoration2]
library=org.kde.breeze
theme=Breeze

[kwinrc][Compositing]
Backend=OpenGL
Enabled=true
GLCore=true

[kwinrc][Plugins]
blurEnabled=true
contrastEnabled=true
dimscreenEnabled=true
overviewEnabled=true
slideEnabled=true

[kwinrc][Windows]
BorderlessMaximizedWindows=false

[plasmarc][Theme]
name=breeze-dark

[Wallpaper]
Image=/usr/share/edpearos/wallpapers/default.png
