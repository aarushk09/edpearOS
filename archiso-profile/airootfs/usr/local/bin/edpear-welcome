#!/usr/bin/env python3
"""
edpear-welcome — edpearOS Welcome & Study Launcher

A GTK4/Libadwaita welcome app that opens on first boot.
Asks the student what they're studying and launches the relevant workspace.
Also used as the "What are you studying today?" quick launcher.

Usage:
  edpear-welcome              Launch the welcome/study picker
  edpear-welcome --setup      Run first-boot setup wizard
  edpear-welcome --reset      Reset first-boot flag (re-run wizard)
"""

import gi
import os
import sys
import json
import subprocess
from pathlib import Path

gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gtk, Adw, Gio, GLib

APP_ID = "org.edpearos.welcome"
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "edpearos"
PREFS_FILE = CONFIG_DIR / "preferences.json"
WIZARD_DONE = CONFIG_DIR / ".wizard-done"

# ═══════════════════════════════════════════════════════════
# Study Workspaces — each opens relevant apps
# ═══════════════════════════════════════════════════════════
WORKSPACES = {
    "STEM": {
        "icon": "accessories-calculator",
        "subtitle": "Math, Physics, Engineering, CS",
        "description": "Opens: LibreOffice Calc, Python, Terminal, Calculator",
        "apps": ["kcalc", "konsole", "libreoffice --calc", "kate"],
        "packages_extra": ["texlive-basic", "python", "python-numpy", "python-matplotlib"],
    },
    "Writing": {
        "icon": "accessories-text-editor",
        "subtitle": "English, History, Philosophy, Essays",
        "description": "Opens: LibreOffice Writer, Obsidian, Zotero",
        "apps": ["libreoffice --writer", "obsidian", "zotero"],
        "packages_extra": ["texlive-latexrecommended"],
    },
    "Research": {
        "icon": "system-search",
        "subtitle": "Academic papers, Citations, Notes",
        "description": "Opens: Zotero, Firefox, Obsidian, File Manager",
        "apps": ["zotero", "firefox", "obsidian", "dolphin"],
        "packages_extra": [],
    },
    "Art & Design": {
        "icon": "applications-graphics",
        "subtitle": "Visual arts, Graphic design, UI/UX",
        "description": "Opens: GIMP, Inkscape, File Manager",
        "apps": ["gimp", "inkscape", "dolphin"],
        "packages_extra": ["gimp", "inkscape", "krita"],
    },
    "Programming": {
        "icon": "utilities-terminal",
        "subtitle": "Software development, Web, Data Science",
        "description": "Opens: VS Code, Terminal, Firefox",
        "apps": ["code", "konsole", "firefox"],
        "packages_extra": ["code", "nodejs", "npm", "python", "docker"],
    },
    "General Study": {
        "icon": "applications-education",
        "subtitle": "Mixed subjects, Homework, Reviews",
        "description": "Opens: File Manager, LibreOffice, Firefox, Notes",
        "apps": ["dolphin", "libreoffice", "firefox", "obsidian"],
        "packages_extra": [],
    },
}

SHORTCUTS_INFO = """
<b>Keyboard Shortcuts</b>

<b>Super + N</b>  — Open Obsidian (Notes)
<b>Super + C</b>  — Open Calculator
<b>Super + T</b>  — Open Terminal
<b>Super + E</b>  — Open File Manager
<b>Super + F</b>  — Toggle Focus Mode
<b>Super + B</b>  — Open Firefox (Browser)
<b>Super + Space</b> — Application Launcher
"""


def load_prefs():
    """Load user preferences from JSON file."""
    if PREFS_FILE.exists():
        try:
            return json.loads(PREFS_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return {}


def save_prefs(prefs):
    """Save user preferences to JSON file."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    PREFS_FILE.write_text(json.dumps(prefs, indent=2))


def launch_workspace(name):
    """Launch all apps in a workspace."""
    ws = WORKSPACES.get(name)
    if not ws:
        return
    for app_cmd in ws["apps"]:
        try:
            subprocess.Popen(
                app_cmd.split(),
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except FileNotFoundError:
            pass  # App not installed, skip silently


class SetupPage(Gtk.Box):
    """First-boot setup wizard page."""

    def __init__(self, app):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=20)
        self.app = app
        self.set_margin_top(40)
        self.set_margin_bottom(40)
        self.set_margin_start(40)
        self.set_margin_end(40)

        # Title
        title = Gtk.Label(label="Welcome to edpearOS")
        title.add_css_class("title-1")
        self.append(title)

        subtitle = Gtk.Label(label="The Modern Student Desktop")
        subtitle.add_css_class("title-3")
        subtitle.set_opacity(0.7)
        self.append(subtitle)

        desc = Gtk.Label(
            label="Let's set up your workspace. This takes about 30 seconds."
        )
        desc.set_wrap(True)
        desc.set_margin_top(10)
        self.append(desc)

        # Name entry
        name_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        name_label = Gtk.Label(label="What's your name?", xalign=0)
        name_label.add_css_class("heading")
        name_box.append(name_label)
        self.name_entry = Gtk.Entry()
        self.name_entry.set_placeholder_text("Student")
        name_box.append(self.name_entry)
        self.append(name_box)

        # Major selection
        major_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        major_label = Gtk.Label(label="What do you study most?", xalign=0)
        major_label.add_css_class("heading")
        major_box.append(major_label)

        self.major_combo = Gtk.DropDown.new_from_strings(list(WORKSPACES.keys()))
        self.major_combo.set_selected(0)
        major_box.append(self.major_combo)
        self.append(major_box)

        # Focus mode preference
        focus_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        focus_label = Gtk.Label(label="Focus Mode preference", xalign=0)
        focus_label.add_css_class("heading")
        focus_box.append(focus_label)

        self.focus_combo = Gtk.DropDown.new_from_strings(
            [
                "Manual only (I'll toggle it myself)",
                "Suggest during school hours (8am-3pm)",
                "Always suggest when laptop opens",
            ]
        )
        self.focus_combo.set_selected(0)
        focus_box.append(self.focus_combo)
        self.append(focus_box)

        # Continue button
        btn = Gtk.Button(label="Get Started →")
        btn.add_css_class("suggested-action")
        btn.add_css_class("pill")
        btn.set_margin_top(20)
        btn.connect("clicked", self.on_continue)
        self.append(btn)

    def on_continue(self, _btn):
        """Save preferences and mark wizard as done."""
        name = self.name_entry.get_text().strip() or "Student"
        majors = list(WORKSPACES.keys())
        major = majors[self.focus_combo.get_selected()] if self.major_combo.get_selected() < len(majors) else "General Study"
        focus_opts = ["manual", "school_hours", "always"]
        focus_pref = focus_opts[self.focus_combo.get_selected()]

        prefs = {
            "name": name,
            "major": major,
            "focus_preference": focus_pref,
            "setup_date": GLib.DateTime.new_now_local().format_iso8601(),
        }
        save_prefs(prefs)

        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        WIZARD_DONE.touch()

        self.app.show_launcher()


class LauncherPage(Gtk.Box):
    """Main study launcher — 'What are you studying today?'"""

    def __init__(self, app):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        self.app = app
        self.set_margin_top(30)
        self.set_margin_bottom(30)
        self.set_margin_start(30)
        self.set_margin_end(30)

        prefs = load_prefs()
        name = prefs.get("name", "Student")

        # Greeting
        greeting = Gtk.Label(label=f"Hey {name}, what are you studying today?")
        greeting.add_css_class("title-2")
        greeting.set_wrap(True)
        self.append(greeting)

        # Workspace cards
        flow = Gtk.FlowBox()
        flow.set_homogeneous(True)
        flow.set_max_children_per_line(3)
        flow.set_min_children_per_line(2)
        flow.set_column_spacing(12)
        flow.set_row_spacing(12)
        flow.set_valign(Gtk.Align.START)
        flow.set_selection_mode(Gtk.SelectionMode.NONE)

        for ws_name, ws_info in WORKSPACES.items():
            card = self._make_card(ws_name, ws_info)
            flow.append(card)

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)
        scrolled.set_child(flow)
        self.append(scrolled)

        # Bottom bar with shortcuts info and focus toggle
        bottom = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        bottom.set_halign(Gtk.Align.CENTER)

        focus_btn = Gtk.Button(label="🎯 Toggle Focus Mode")
        focus_btn.add_css_class("pill")
        focus_btn.connect("clicked", self.on_focus_toggle)
        bottom.append(focus_btn)

        shortcuts_btn = Gtk.Button(label="⌨ Shortcuts")
        shortcuts_btn.add_css_class("pill")
        shortcuts_btn.connect("clicked", self.on_shortcuts)
        bottom.append(shortcuts_btn)

        self.append(bottom)

    def _make_card(self, name, info):
        """Create a workspace card widget."""
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_margin_top(12)
        box.set_margin_bottom(12)
        box.set_margin_start(12)
        box.set_margin_end(12)

        icon = Gtk.Image.new_from_icon_name(info["icon"])
        icon.set_pixel_size(48)
        box.append(icon)

        title = Gtk.Label(label=name)
        title.add_css_class("title-4")
        box.append(title)

        sub = Gtk.Label(label=info["subtitle"])
        sub.set_opacity(0.6)
        sub.set_wrap(True)
        sub.set_max_width_chars(25)
        sub.set_justify(Gtk.Justification.CENTER)
        box.append(sub)

        btn = Gtk.Button(label="Launch →")
        btn.add_css_class("suggested-action")
        btn.add_css_class("pill")
        btn.connect("clicked", lambda _b, n=name: self.on_launch(n))
        box.append(btn)

        return box

    def on_launch(self, ws_name):
        """Launch the selected workspace and close the welcome app."""
        launch_workspace(ws_name)
        self.app.quit()

    def on_focus_toggle(self, _btn):
        """Toggle focus mode via CLI."""
        subprocess.Popen(
            ["/usr/local/bin/edpear-focus", "toggle"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    def on_shortcuts(self, _btn):
        """Show keyboard shortcuts dialog."""
        dialog = Adw.MessageDialog.new(self.app.get_active_window())
        dialog.set_heading("edpearOS Shortcuts")
        dialog.set_body_use_markup(True)
        dialog.set_body(SHORTCUTS_INFO)
        dialog.add_response("ok", "Got it")
        dialog.present()


class EdpearWelcomeApp(Adw.Application):
    """Main application class."""

    def __init__(self, force_setup=False):
        super().__init__(application_id=APP_ID)
        self.force_setup = force_setup

    def do_activate(self):
        win = Adw.ApplicationWindow(application=self)
        win.set_title("edpearOS")
        win.set_default_size(700, 550)
        win.set_resizable(True)

        self.header = Adw.HeaderBar()
        self.header.set_title_widget(Gtk.Label(label="edpearOS"))

        self.content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.content_box.append(self.header)

        if self.force_setup or not WIZARD_DONE.exists():
            page = SetupPage(self)
        else:
            page = LauncherPage(self)

        self.page_container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.page_container.set_vexpand(True)
        self.page_container.append(page)
        self.content_box.append(self.page_container)

        win.set_content(self.content_box)
        win.present()

    def show_launcher(self):
        """Switch from setup page to launcher page."""
        child = self.page_container.get_first_child()
        if child:
            self.page_container.remove(child)
        self.page_container.append(LauncherPage(self))


def main():
    force_setup = "--setup" in sys.argv
    if "--reset" in sys.argv:
        if WIZARD_DONE.exists():
            WIZARD_DONE.unlink()
        print("First-boot flag reset. Run edpear-welcome to re-run wizard.")
        return

    app = EdpearWelcomeApp(force_setup=force_setup)
    app.run([])


if __name__ == "__main__":
    main()
